# 기본적으로 모든 파일 무시
*

# 디렉토리는 traverse 가능하도록 허용 (하위에 화이트리스트 파일이 있으면 따라감)
!*/

# 추적 대상 화이트리스트
!*.py
!*.md
!requirements.txt
!.gitignore
!.streamlit/config.toml
!.github/workflows/*.yml
!.github/workflows/*.yaml
# Streamlit Cloud 배포를 위해 docs 결과 파일도 git 추적 (GitHub Actions가 자동 갱신)
!docs/**/*.csv
!docs/**/*.txt
